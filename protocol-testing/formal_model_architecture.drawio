        <mxCell id="r13c" value="(None)&lt;br&gt;No APT model" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f8cecc;fontSize=9;align=left;spacingLeft=4;" vertex="1" parent="1">
          <mxGeometry x="550" y="645" width="200" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="r13m" value="✅ APT lifecycle&lt;br&gt;Malicious frames + packets" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;fontSize=9;align=left;spacingLeft=4;" vertex="1" parent="1">
          <mxGeometry x="750" y="645" width="170" height="50" as="geometry"/>
