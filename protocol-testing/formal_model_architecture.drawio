        <!-- Attacks Stack -->
        <mxCell id="atk_opt" value="&lt;b&gt;ATTACKS STACK&lt;/b&gt;&lt;br&gt;&lt;i&gt;{prot}_attacks_stack/&lt;/i&gt;&lt;br&gt;&lt;hr&gt;• Forged packets (initial, short header)&lt;br&gt;• Replayed packets (0-RTT)&lt;br&gt;• Forged datagrams&lt;br&gt;&lt;font color=&quot;#CC0000&quot;&gt;⚑ Protocol-specific attack vectors&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;align=left;verticalAlign=top;spacingLeft=8;spacingTop=4;fontSize=10;" vertex="1" parent="1">
