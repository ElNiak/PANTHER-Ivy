        </mxCell>

        <!-- File I/O -->
        <mxCell id="file_layer" value="&lt;b&gt;FILE I/O&lt;/b&gt;&lt;br&gt;&lt;i&gt;file.ivy&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;" vertex="1" parent="1">
