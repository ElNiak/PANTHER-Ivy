        <mxCell id="entity_header" value="&lt;b&gt;ENTITY MODEL&lt;/b&gt;&lt;br&gt;&lt;i&gt;{prot}_entities/&lt;/i&gt;" style="text;html=1;align=center;fontSize=13;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="780" y="0" width="200" height="40" as="geometry"/>
        </mxCell>

        <!-- Entity Definitions -->
        <mxCell id="entity_def" value="&lt;b&gt;ENTITY DEFINITIONS&lt;/b&gt;&lt;br&gt;&lt;i&gt;ivy_{prot}_{role}.ivy&lt;/i&gt;&lt;br&gt;&lt;hr&gt;• Instance parameters (addr, port, CID)&lt;br&gt;• Role assignment&lt;br&gt;• Network endpoint configuration&lt;br&gt;&lt;font color=&quot;#CC0000&quot;&gt;⚑ Protocol-specific: entity roles&lt;br&gt;Client/Server (QUIC, CoAP) vs Speaker (BGP)&lt;br&gt;+ MIM, Attacker, Victim for security testing&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;align=left;verticalAlign=top;spacingLeft=8;spacingTop=4;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="730" y="50" width="300" height="140" as="geometry"/>
        </mxCell>

        <!-- Entity Behavior -->
        <mxCell id="entity_beh" value="&lt;b&gt;ENTITY BEHAVIOR&lt;/b&gt;&lt;br&gt;&lt;i&gt;{prot}_entities_behavior/&lt;/i&gt;&lt;br&gt;&lt;i&gt;ivy_{prot}_{role}_behavior.ivy&lt;/i&gt;&lt;br&gt;&lt;hr&gt;• Protocol FSM implementation&lt;br&gt;• Action handlers (before/after)&lt;br&gt;• Constraint specifications (require)&lt;br&gt;• Event generation logic&lt;br&gt;• Socket management&lt;br&gt;&lt;font color=&quot;#CC0000&quot;&gt;⚑ Protocol-specific: all behavioral logic,&lt;br&gt;state transitions, and constraints&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;align=left;verticalAlign=top;spacingLeft=8;spacingTop=4;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="730" y="210" width="300" height="170" as="geometry"/>
        </mxCell>

        <!-- Shims -->
        <mxCell id="shim_layer" value="&lt;b&gt;SHIMS (Implementation Bridge)&lt;/b&gt;&lt;br&gt;&lt;i&gt;{prot}_shims/{prot}_shim.ivy&lt;/i&gt;&lt;br&gt;&lt;hr&gt;• UDP/TCP datagram reception → deserialization&lt;br&gt;• Packet encryption/decryption calls&lt;br&gt;• TLS API integration&lt;br&gt;• Network socket binding&lt;br&gt;• Serializer/deserializer instantiation&lt;br&gt;&lt;font color=&quot;#CC0000&quot;&gt;⚑ Mixed: generic bridge pattern,&lt;br&gt;protocol-specific transport (UDP/TCP),&lt;br&gt;protocol-specific crypto integration&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;align=left;verticalAlign=top;spacingLeft=8;spacingTop=4;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="730" y="400" width="300" height="170" as="geometry"/>
        </mxCell>

        <!-- Configuration -->
        <mxCell id="config_layer" value="&lt;b&gt;CONFIGURATION&lt;/b&gt;&lt;br&gt;&lt;i&gt;{prot}_config/&lt;/i&gt;&lt;br&gt;&lt;hr&gt;• Transport parameter presets&lt;br&gt;• Test scenario configurations&lt;br&gt;• Feature flags&lt;br&gt;&lt;font color=&quot;#CC0000&quot;&gt;⚑ Protocol-specific: parameter values&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;align=left;verticalAlign=top;spacingLeft=8;spacingTop=4;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="730" y="590" width="300" height="105" as="geometry"/>
        </mxCell>

        <!-- Tests -->
        <mxCell id="test_layer" value="&lt;b&gt;TEST HARNESSES&lt;/b&gt;&lt;br&gt;&lt;i&gt;{prot}_tests/&lt;/i&gt;&lt;br&gt;&lt;hr&gt;• Test composition (entities+behavior+shim)&lt;br&gt;• .ivy test files + .dsc descriptors&lt;br&gt;• Client tests / Server tests / MIM tests&lt;br&gt;&lt;font color=&quot;#CC0000&quot;&gt;⚑ Protocol-specific: test scenarios,&lt;br&gt;compliance requirements, edge cases&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;align=left;verticalAlign=top;spacingLeft=8;spacingTop=4;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="730" y="715" width="300" height="120" as="geometry"/>
