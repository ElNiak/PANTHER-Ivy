        </mxCell>

        <!-- Time -->
        <mxCell id="time_layer" value="&lt;b&gt;TIME&lt;/b&gt;&lt;br&gt;&lt;i&gt;{prot}_time.ivy&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;" vertex="1" parent="1">
