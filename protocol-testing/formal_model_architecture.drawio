        <!-- ============================================ -->
        <!-- CORE PROTOCOL STACK (Center Column) -->
        <!-- ============================================ -->

        <mxCell id="stack_header" value="&lt;b&gt;PROTOCOL STACK&lt;/b&gt;&lt;br&gt;&lt;i&gt;{prot}_stack/&lt;/i&gt;" style="text;html=1;align=center;fontSize=13;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="370" y="0" width="200" height="40" as="geometry"/>
        </mxCell>

        <!-- Application Layer -->
        <mxCell id="app_layer" value="&lt;b&gt;APPLICATION LAYER&lt;/b&gt;&lt;br&gt;&lt;i&gt;{prot}_application.ivy&lt;/i&gt;&lt;br&gt;&lt;hr&gt;• app_server_open_event&lt;br&gt;• app_send_event / app_recv_event&lt;br&gt;• Stream data management&lt;br&gt;&lt;font color=&quot;#CC0000&quot;&gt;⚑ Protocol-specific: data transfer semantics,&lt;br&gt;stream vs message vs route model&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;align=left;verticalAlign=top;spacingLeft=8;spacingTop=4;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="250" y="50" width="440" height="130" as="geometry"/>
        </mxCell>

        <!-- Security Layer -->
        <mxCell id="sec_layer" value="&lt;b&gt;SECURITY / HANDSHAKE LAYER&lt;/b&gt;&lt;br&gt;&lt;i&gt;{prot}_security.ivy&lt;/i&gt;&lt;br&gt;&lt;hr&gt;• tls_send_event / tls_recv_event&lt;br&gt;• Key establishment events&lt;br&gt;• Handshake state tracking&lt;br&gt;&lt;font color=&quot;#CC0000&quot;&gt;⚑ Protocol-specific: TLS 1.3 (QUIC), DTLS (CoAP),&lt;br&gt;TCP-MD5/IPsec (BGP), none (MiniP)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;align=left;verticalAlign=top;spacingLeft=8;spacingTop=4;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="250" y="200" width="440" height="120" as="geometry"/>
        </mxCell>

        <!-- Frame/Message Layer -->
        <mxCell id="frame_layer" value="&lt;b&gt;FRAME / MESSAGE LAYER&lt;/b&gt;&lt;br&gt;&lt;i&gt;{prot}_frame.ivy / {prot}_message.ivy&lt;/i&gt;&lt;br&gt;&lt;hr&gt;• Frame type definitions (variant structs)&lt;br&gt;• Frame handler actions (handle_{type})&lt;br&gt;• Frame queuing and encryption level&lt;br&gt;&lt;font color=&quot;#CC0000&quot;&gt;⚑ Protocol-specific: frame types (QUIC: 20+,&lt;br&gt;BGP: 4 msg types, CoAP: methods+options)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;align=left;verticalAlign=top;spacingLeft=8;spacingTop=4;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="250" y="340" width="440" height="130" as="geometry"/>
        </mxCell>

        <!-- Packet Layer -->
        <mxCell id="pkt_layer" value="&lt;b&gt;PACKET LAYER&lt;/b&gt;&lt;br&gt;&lt;i&gt;{prot}_packet.ivy&lt;/i&gt;&lt;br&gt;&lt;hr&gt;• Packet structure (header + payload)&lt;br&gt;• Packet types and variants&lt;br&gt;• packet_event action + monitors&lt;br&gt;&lt;font color=&quot;#CC0000&quot;&gt;⚑ Protocol-specific: header format, packet types&lt;br&gt;(QUIC: long/short; BGP: via TCP stream)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;align=left;verticalAlign=top;spacingLeft=8;spacingTop=4;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="250" y="490" width="440" height="120" as="geometry"/>
        </mxCell>

        <!-- Protection Layer -->
        <mxCell id="prot_layer" value="&lt;b&gt;PROTECTION LAYER&lt;/b&gt;&lt;br&gt;&lt;i&gt;{prot}_protection.ivy&lt;/i&gt;&lt;br&gt;&lt;hr&gt;• Encryption / Decryption procedures&lt;br&gt;• Header protection&lt;br&gt;• AEAD operations, key material&lt;br&gt;&lt;font color=&quot;#CC0000&quot;&gt;⚑ Protocol-specific: crypto algorithms,&lt;br&gt;encryption levels, protection scheme&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;align=left;verticalAlign=top;spacingLeft=8;spacingTop=4;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="250" y="630" width="440" height="115" as="geometry"/>
        </mxCell>

        <!-- Connection/State Management -->
        <mxCell id="conn_layer" value="&lt;b&gt;CONNECTION / STATE MANAGEMENT&lt;/b&gt;&lt;br&gt;&lt;i&gt;{prot}_connection.ivy / {prot}_state_management.ivy&lt;/i&gt;&lt;br&gt;&lt;hr&gt;• Connection state relations&lt;br&gt;• CID/session mapping&lt;br&gt;• Connection lifecycle events&lt;br&gt;&lt;font color=&quot;#CC0000&quot;&gt;⚑ Protocol-specific: state machine, connection IDs,&lt;br&gt;session model (QUIC CID, BGP FSM, CoAP token)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;align=left;verticalAlign=top;spacingLeft=8;spacingTop=4;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="250" y="765" width="440" height="120" as="geometry"/>
        </mxCell>

        <!-- Transport Parameters -->
        <mxCell id="tp_layer" value="&lt;b&gt;TRANSPORT PARAMETERS&lt;/b&gt;&lt;br&gt;&lt;i&gt;{prot}_transport_parameters.ivy&lt;/i&gt;&lt;br&gt;&lt;hr&gt;• Negotiable protocol parameters&lt;br&gt;• Parameter encoding/decoding&lt;br&gt;&lt;font color=&quot;#CC0000&quot;&gt;⚑ Protocol-specific: parameter set (QUIC: 20+ TPs,&lt;br&gt;BGP: optional params, CoAP: transmission params)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;align=left;verticalAlign=top;spacingLeft=8;spacingTop=4;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="250" y="905" width="215" height="110" as="geometry"/>
        </mxCell>

        <!-- Error Handling -->
        <mxCell id="err_layer" value="&lt;b&gt;ERROR HANDLING&lt;/b&gt;&lt;br&gt;&lt;i&gt;{prot}_error_code.ivy&lt;/i&gt;&lt;br&gt;&lt;hr&gt;• Error code enumerations&lt;br&gt;• Error handler actions&lt;br&gt;&lt;font color=&quot;#CC0000&quot;&gt;⚑ Protocol-specific: error taxonomy&lt;br&gt;(QUIC: transport+H3 errors, BGP: notification codes)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;align=left;verticalAlign=top;spacingLeft=8;spacingTop=4;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="475" y="905" width="215" height="110" as="geometry"/>
        </mxCell>

        <!-- Types -->
        <mxCell id="types_layer" value="&lt;b&gt;TYPE DEFINITIONS&lt;/b&gt;&lt;br&gt;&lt;i&gt;{prot}_types.ivy&lt;/i&gt;&lt;br&gt;&lt;hr&gt;• ID types (cid, stream_id, pkt_num)&lt;br&gt;• Bit vector types&lt;br&gt;• Enumerations (roles, types)&lt;br&gt;&lt;font color=&quot;#CC0000&quot;&gt;⚑ Protocol-specific: all type defs&lt;br&gt;(QUIC: CID/stream, BGP: AS#, CoAP: token)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;align=left;verticalAlign=top;spacingLeft=8;spacingTop=4;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="250" y="1035" width="440" height="110" as="geometry"/>
