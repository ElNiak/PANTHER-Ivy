        <mxCell id="r9c" value="⚠️ coap_ser.ivy / coap_deser.ivy&lt;br&gt;EMPTY (0 bytes)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f8cecc;fontSize=9;align=left;spacingLeft=4;" vertex="1" parent="1">
          <mxGeometry x="550" y="445" width="200" height="50" as="geometry"/>
