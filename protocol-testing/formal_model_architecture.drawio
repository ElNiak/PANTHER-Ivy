        </mxCell>

        <!-- APT Lifecycle -->
        <mxCell id="apt_life" value="&lt;b&gt;APT LIFECYCLE&lt;/b&gt;&lt;br&gt;&lt;i&gt;apt_lifecycle/&lt;/i&gt;&lt;br&gt;&lt;hr&gt;1. Reconnaissance (scanning, DNS, WHOIS)&lt;br&gt;2. Infiltration (phishing, zero-day)&lt;br&gt;3. C2 Communication (backdoors)&lt;br&gt;4. Privilege Escalation (lateral movement)&lt;br&gt;5. Maintain Persistence (obfuscation)&lt;br&gt;6. Data Exfiltration (covert channels)&lt;br&gt;+ White Noise (DDoS distraction)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;align=left;verticalAlign=top;spacingLeft=8;spacingTop=4;fontSize=10;" vertex="1" parent="1">
