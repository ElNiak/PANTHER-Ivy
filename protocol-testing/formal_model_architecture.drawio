        <!-- ============================================ -->

        <mxCell id="opt_header" value="&lt;b&gt;OPTIONAL LAYERS&lt;/b&gt;" style="text;html=1;align=center;fontSize=13;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="-20" y="0" width="200" height="30" as="geometry"/>
        </mxCell>

        <!-- Security Sub-Protocol -->
        <mxCell id="tls_stack" value="&lt;b&gt;SECURITY SUB-PROTOCOL&lt;/b&gt;&lt;br&gt;&lt;i&gt;tls_stack/ or dtls_stack/&lt;/i&gt;&lt;br&gt;&lt;hr&gt;• tls_protocol.ivy&lt;br&gt;• tls_record.ivy&lt;br&gt;• tls_deser_ser.ivy&lt;br&gt;&lt;font color=&quot;#CC0000&quot;&gt;⚑ TLS 1.3 (QUIC), DTLS (CoAP),&lt;br&gt;or custom (BGP)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;align=left;verticalAlign=top;spacingLeft=8;spacingTop=4;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="-50" y="50" width="250" height="130" as="geometry"/>
        </mxCell>

        <!-- FSM Modules -->
        <mxCell id="fsm_opt" value="&lt;b&gt;FSM MODULES&lt;/b&gt;&lt;br&gt;&lt;i&gt;{prot}_fsm/&lt;/i&gt;&lt;br&gt;&lt;hr&gt;• quic_fsm_sending.ivy&lt;br&gt;• quic_fsm_receiving.ivy&lt;br&gt;• coap_state_management.ivy&lt;br&gt;&lt;font color=&quot;#CC0000&quot;&gt;⚑ Protocol-specific states&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;align=left;verticalAlign=top;spacingLeft=8;spacingTop=4;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="-50" y="200" width="250" height="120" as="geometry"/>
        </mxCell>

        <!-- Recovery/Congestion -->
        <mxCell id="recovery_opt" value="&lt;b&gt;RECOVERY &amp;amp; CONGESTION&lt;/b&gt;&lt;br&gt;&lt;i&gt;{prot}_recovery/ or {prot}_congestion/&lt;/i&gt;&lt;br&gt;&lt;hr&gt;• Loss detection (quic_loss_recovery)&lt;br&gt;• Congestion control (quic_congestion_control)&lt;br&gt;• Retransmission (coap_retransmission)&lt;br&gt;• Network controller&lt;br&gt;&lt;font color=&quot;#CC0000&quot;&gt;⚑ Only for protocols with built-in reliability&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;align=left;verticalAlign=top;spacingLeft=8;spacingTop=4;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="-50" y="340" width="250" height="140" as="geometry"/>
        </mxCell>

        <!-- Extensions -->
        <mxCell id="ext_opt" value="&lt;b&gt;EXTENSIONS&lt;/b&gt;&lt;br&gt;&lt;i&gt;{prot}_extensions/&lt;/i&gt;&lt;br&gt;&lt;hr&gt;• quic_ack_frequency_extension&lt;br&gt;• quic_vn_ext&lt;br&gt;&lt;font color=&quot;#CC0000&quot;&gt;⚑ If protocol has extension mechanism&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;align=left;verticalAlign=top;spacingLeft=8;spacingTop=4;fontSize=10;" vertex="1" parent="1">
