          <mxGeometry x="390" y="1210" width="130" height="60" as="geometry"/>
        </mxCell>

        <!-- Byte Stream -->
        <mxCell id="bs_layer" value="&lt;b&gt;BYTE STREAM&lt;/b&gt;&lt;br&gt;&lt;i&gt;byte_stream.ivy&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;" vertex="1" parent="1">
