        <mxCell id="r9m" value="✅ ping_ser.ivy / ping_deser.ivy&lt;br&gt;C++ binary ser/deser" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;fontSize=9;align=left;spacingLeft=4;" vertex="1" parent="1">
          <mxGeometry x="750" y="445" width="170" height="50" as="geometry"/>
        </mxCell>

        <!-- Row 10: Security Stack -->
        <mxCell id="r10l" value="&lt;b&gt;Security Stack&lt;/b&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="-20" y="495" width="150" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="r10q" value="✅ tls_stack/ (TLS 1.3)&lt;br&gt;6 files: protocol, record, deser_ser, test" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;fontSize=9;align=left;spacingLeft=4;" vertex="1" parent="1">
          <mxGeometry x="130" y="495" width="220" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="r10b" value="(N/A — uses TCP-MD5 / custom)&lt;br&gt;Handled in bgp_protection" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;fontSize=9;align=left;spacingLeft=4;" vertex="1" parent="1">
          <mxGeometry x="350" y="495" width="200" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="r10c" value="✅ dtls_stack/ (DTLS/TLS 1.2)&lt;br&gt;4 files: protocol, record, infer, deser_ser" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;fontSize=9;align=left;spacingLeft=4;" vertex="1" parent="1">
          <mxGeometry x="550" y="495" width="200" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="r10m" value="(None)&lt;br&gt;No security layer" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;fontSize=9;align=left;spacingLeft=4;" vertex="1" parent="1">
          <mxGeometry x="750" y="495" width="170" height="50" as="geometry"/>
        </mxCell>

        <!-- Row 11: Recovery -->
        <mxCell id="r11l" value="&lt;b&gt;Recovery/&lt;br&gt;Congestion&lt;/b&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="-20" y="545" width="150" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="r11q" value="✅ quic_recovery/ (3 files)&lt;br&gt;Loss detection, congestion control, RTT" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;fontSize=9;align=left;spacingLeft=4;" vertex="1" parent="1">
          <mxGeometry x="130" y="545" width="220" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="r11b" value="(N/A — TCP handles this)&lt;br&gt;Not applicable" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;fontSize=9;align=left;spacingLeft=4;" vertex="1" parent="1">
          <mxGeometry x="350" y="545" width="200" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="r11c" value="✅ coap_congestion/ (3 files)&lt;br&gt;Retransmission, network controller" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;fontSize=9;align=left;spacingLeft=4;" vertex="1" parent="1">
          <mxGeometry x="550" y="545" width="200" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="r11m" value="(None)&lt;br&gt;No recovery needed" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;fontSize=9;align=left;spacingLeft=4;" vertex="1" parent="1">
          <mxGeometry x="750" y="545" width="170" height="50" as="geometry"/>
        </mxCell>

        <!-- Row 12: Tests -->
        <mxCell id="r12l" value="&lt;b&gt;Tests&lt;/b&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="-20" y="595" width="150" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="r12q" value="✅ 140+ test files&lt;br&gt;server/client/MIM tests" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;fontSize=9;align=left;spacingLeft=4;" vertex="1" parent="1">
          <mxGeometry x="130" y="595" width="220" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="r12b" value="✅ 2 speaker tests&lt;br&gt;accept + join" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;fontSize=9;align=left;spacingLeft=4;" vertex="1" parent="1">
          <mxGeometry x="350" y="595" width="200" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="r12c" value="(None yet)&lt;br&gt;No test directory" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f8cecc;fontSize=9;align=left;spacingLeft=4;" vertex="1" parent="1">
          <mxGeometry x="550" y="595" width="200" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="r12m" value="✅ Client + server tests&lt;br&gt;2 test suites" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;fontSize=9;align=left;spacingLeft=4;" vertex="1" parent="1">
          <mxGeometry x="750" y="595" width="170" height="50" as="geometry"/>
        </mxCell>

        <!-- Row 13: APT Integration -->
        <mxCell id="r13l" value="&lt;b&gt;APT Integration&lt;/b&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#e1d5e7;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="-20" y="645" width="150" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="r13q" value="✅ Full APT lifecycle&lt;br&gt;Malicious frames, packets, attack connections" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;fontSize=9;align=left;spacingLeft=4;" vertex="1" parent="1">
          <mxGeometry x="130" y="645" width="220" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="r13b" value="(None)&lt;br&gt;No APT model" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f8cecc;fontSize=9;align=left;spacingLeft=4;" vertex="1" parent="1">
          <mxGeometry x="350" y="645" width="200" height="50" as="geometry"/>
