        <mxCell id="r8c" value="✅ coap_shim.ivy + client/server&lt;br&gt;UDP-based" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;fontSize=9;align=left;spacingLeft=4;" vertex="1" parent="1">
          <mxGeometry x="550" y="395" width="200" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="r8m" value="✅ ping_shim.ivy + variants&lt;br&gt;UDP-based" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;fontSize=9;align=left;spacingLeft=4;" vertex="1" parent="1">
          <mxGeometry x="750" y="395" width="170" height="50" as="geometry"/>
        </mxCell>

        <!-- Row 9: Ser/Deser -->
        <mxCell id="r9l" value="&lt;b&gt;Ser/Deser&lt;/b&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="-20" y="445" width="150" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="r9q" value="✅ 12+ file pairs (standard, 0RTT, retry, VN, forged)&lt;br&gt;~47k lines total" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;fontSize=9;align=left;spacingLeft=4;" vertex="1" parent="1">
          <mxGeometry x="130" y="445" width="220" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="r9b" value="✅ 10+ files (per msg type)&lt;br&gt;bgp_ser_*.ivy / bgp_deser_*.ivy" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;fontSize=9;align=left;spacingLeft=4;" vertex="1" parent="1">
