      </root>
    </mxGraphModel>
  </diagram>

  <!-- PAGE 3: Protocol Category Adaptations -->
  <diagram id="page3" name="Category Adaptations">
    <mxGraphModel dx="1800" dy="1400" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="0" pageScale="1" pageWidth="1654" pageHeight="1169" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <mxCell id="t3" value="&lt;b&gt;TEMPLATE ADAPTATIONS FOR OTHER NETWORK PROTOCOL CATEGORIES&lt;/b&gt;&lt;br&gt;How the general template changes for different protocol families" style="text;html=1;align=center;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="50" y="-50" width="800" height="50" as="geometry"/>
        </mxCell>

        <!-- Category 1: Connection-oriented Transport -->
        <mxCell id="cat1" value="&lt;b&gt;CONNECTION-ORIENTED TRANSPORT&lt;/b&gt;&lt;br&gt;&lt;i&gt;(SSH, SMTP, FTP, MQTT/TCP, HTTP/1.1)&lt;/i&gt;&lt;hr&gt;&lt;b&gt;Template changes:&lt;/b&gt;&lt;br&gt;• Replace UDP datagram layer → TCP stream layer&lt;br&gt;• Packet layer simplified (TCP handles segmentation)&lt;br&gt;• Add TCP connection FSM (3-way handshake)&lt;br&gt;• Recovery/congestion NOT needed (TCP handles it)&lt;br&gt;• Serialization is stream-oriented&lt;br&gt;• Shim uses TCP sockets instead of UDP&lt;br&gt;&lt;b&gt;Entity model:&lt;/b&gt; Client/Server or Peer/Peer" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;align=left;verticalAlign=top;spacingLeft=8;spacingTop=4;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="0" y="20" width="280" height="200" as="geometry"/>
        </mxCell>

        <!-- Category 2: Pub/Sub -->
        <mxCell id="cat2" value="&lt;b&gt;PUBLISH / SUBSCRIBE&lt;/b&gt;&lt;br&gt;&lt;i&gt;(MQTT, AMQP, XMPP, DDS)&lt;/i&gt;&lt;hr&gt;&lt;b&gt;Template changes:&lt;/b&gt;&lt;br&gt;• Application layer: topic/subscription management&lt;br&gt;• Add Broker entity (not just client/server)&lt;br&gt;• QoS levels (at-most/least/exactly-once)&lt;br&gt;• Add session persistence layer&lt;br&gt;• Add will/testament messages&lt;br&gt;• Frame layer: CONNECT, PUBLISH, SUBSCRIBE, UNSUBSCRIBE, PINGREQ/RESP&lt;br&gt;&lt;b&gt;Entity model:&lt;/b&gt; Publisher, Subscriber, Broker" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;align=left;verticalAlign=top;spacingLeft=8;spacingTop=4;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="300" y="20" width="280" height="200" as="geometry"/>
        </mxCell>

        <!-- Category 3: Routing -->
        <mxCell id="cat3" value="&lt;b&gt;ROUTING PROTOCOLS&lt;/b&gt;&lt;br&gt;&lt;i&gt;(BGP, OSPF, IS-IS, RIP)&lt;/i&gt;&lt;hr&gt;&lt;b&gt;Template changes:&lt;/b&gt;&lt;br&gt;• Add RIB (Routing Information Base) data structure&lt;br&gt;• Add neighbor/peer discovery module&lt;br&gt;• Add route announcement/withdrawal&lt;br&gt;• Add path computation (Dijkstra, Bellman-Ford)&lt;br&gt;• Add convergence timing model&lt;br&gt;• Add AS/area topology model&lt;br&gt;• Frame layer: HELLO, UPDATE, ACK, NOTIFICATION&lt;br&gt;&lt;b&gt;Entity model:&lt;/b&gt; Speaker/Peer (symmetric)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;align=left;verticalAlign=top;spacingLeft=8;spacingTop=4;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="600" y="20" width="280" height="200" as="geometry"/>
        </mxCell>

        <!-- Category 4: Real-time -->
        <mxCell id="cat4" value="&lt;b&gt;REAL-TIME MEDIA&lt;/b&gt;&lt;br&gt;&lt;i&gt;(RTP, WebRTC, SIP/SDP)&lt;/i&gt;&lt;hr&gt;&lt;b&gt;Template changes:&lt;/b&gt;&lt;br&gt;• Add timing/latency requirements layer&lt;br&gt;• Add jitter buffer model&lt;br&gt;• Add codec negotiation (SDP)&lt;br&gt;• Add companion control protocol (RTCP)&lt;br&gt;• Add session signaling (SIP)&lt;br&gt;• Recovery: FEC, not retransmission&lt;br&gt;• Frame: RTP header + payload&lt;br&gt;&lt;b&gt;Entity model:&lt;/b&gt; Sender, Receiver, Mixer" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;align=left;verticalAlign=top;spacingLeft=8;spacingTop=4;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="0" y="240" width="280" height="200" as="geometry"/>
        </mxCell>

        <!-- Category 5: IoT/Constrained -->
        <mxCell id="cat5" value="&lt;b&gt;IoT / CONSTRAINED DEVICES&lt;/b&gt;&lt;br&gt;&lt;i&gt;(CoAP, MQTT-SN, LwM2M, Zigbee)&lt;/i&gt;&lt;hr&gt;&lt;b&gt;Template changes:&lt;/b&gt;&lt;br&gt;• Add resource discovery (CoRE Link Format)&lt;br&gt;• Add proxy/gateway entity&lt;br&gt;• Add block-wise transfer module&lt;br&gt;• Add observe/notification (pub/sub pattern)&lt;br&gt;• Add constrained resource model&lt;br&gt;• Simplified security (DTLS, OSCORE)&lt;br&gt;• Frame: Compact binary encoding&lt;br&gt;&lt;b&gt;Entity model:&lt;/b&gt; Client, Server, Proxy, Gateway" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;align=left;verticalAlign=top;spacingLeft=8;spacingTop=4;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="300" y="240" width="280" height="200" as="geometry"/>
        </mxCell>

        <!-- Category 6: DNS -->
        <mxCell id="cat6" value="&lt;b&gt;NAME RESOLUTION / QUERY-RESPONSE&lt;/b&gt;&lt;br&gt;&lt;i&gt;(DNS, mDNS, LDAP, RADIUS)&lt;/i&gt;&lt;hr&gt;&lt;b&gt;Template changes:&lt;/b&gt;&lt;br&gt;• Application: query/response matching (txn IDs)&lt;br&gt;• Add record type definitions (A, AAAA, MX...)&lt;br&gt;• Add recursive/iterative resolution model&lt;br&gt;• Add zone transfer module&lt;br&gt;• Add DNSSEC extension (for DNS)&lt;br&gt;• No persistent connection state&lt;br&gt;• Frame: Question + Answer sections&lt;br&gt;&lt;b&gt;Entity model:&lt;/b&gt; Resolver, Auth Server, Recursive" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;align=left;verticalAlign=top;spacingLeft=8;spacingTop=4;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="600" y="240" width="280" height="200" as="geometry"/>
        </mxCell>

        <!-- Category 7: Multiplexed Transport -->
        <mxCell id="cat7" value="&lt;b&gt;MULTIPLEXED SECURE TRANSPORT&lt;/b&gt;&lt;br&gt;&lt;i&gt;(QUIC, HTTP/2, HTTP/3, SCTP)&lt;/i&gt;&lt;hr&gt;&lt;b&gt;Template changes: (most complex)&lt;/b&gt;&lt;br&gt;• Full stream/flow management layer&lt;br&gt;• Full recovery + congestion control&lt;br&gt;• Full FSM modules (send/receive per stream)&lt;br&gt;• Integrated TLS security stack&lt;br&gt;• Connection migration support&lt;br&gt;• Extension mechanism&lt;br&gt;• Multiple encryption levels&lt;br&gt;• Comprehensive attacks stack&lt;br&gt;&lt;b&gt;Entity model:&lt;/b&gt; Client, Server, MIM, Attacker" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;align=left;verticalAlign=top;spacingLeft=8;spacingTop=4;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="0" y="460" width="280" height="210" as="geometry"/>
        </mxCell>

        <!-- Category 8: VPN/Tunnel -->
        <mxCell id="cat8" value="&lt;b&gt;VPN / TUNNELING&lt;/b&gt;&lt;br&gt;&lt;i&gt;(WireGuard, IPsec/IKEv2, OpenVPN, GRE)&lt;/i&gt;&lt;hr&gt;&lt;b&gt;Template changes:&lt;/b&gt;&lt;br&gt;• Add tunnel establishment protocol (IKE)&lt;br&gt;• Add encapsulation/decapsulation layer&lt;br&gt;• Add key exchange module (DH, Noise)&lt;br&gt;• Add SA (Security Association) management&lt;br&gt;• Add anti-replay window&lt;br&gt;• Protection layer is primary concern&lt;br&gt;• Frame: ESP/AH headers, tunnel headers&lt;br&gt;&lt;b&gt;Entity model:&lt;/b&gt; Initiator, Responder, Gateway" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;align=left;verticalAlign=top;spacingLeft=8;spacingTop=4;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="300" y="460" width="280" height="210" as="geometry"/>
        </mxCell>

        <!-- Decision Matrix -->
        <mxCell id="decision" value="&lt;b&gt;TEMPLATE SELECTION DECISION MATRIX&lt;/b&gt;&lt;hr&gt;&lt;table style='font-size:9px;border-collapse:collapse;width:100%'&gt;&lt;tr&gt;&lt;th style='text-align:left;border-bottom:1px solid #999'&gt;Protocol Property&lt;/th&gt;&lt;th style='border-bottom:1px solid #999'&gt;Template Impact&lt;/th&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;Connection-oriented?&lt;/td&gt;&lt;td&gt;→ TCP layer, simplified packet&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;Built-in reliability?&lt;/td&gt;&lt;td&gt;→ Add recovery/congestion modules&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;Multiplexed streams?&lt;/td&gt;&lt;td&gt;→ Add stream mgmt + per-stream FSM&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;Integrated security?&lt;/td&gt;&lt;td&gt;→ Add TLS/DTLS stack + protection&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;Peer-to-peer?&lt;/td&gt;&lt;td&gt;→ Symmetric entities (Speaker/Peer)&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;Pub/Sub pattern?&lt;/td&gt;&lt;td&gt;→ Add broker + topic/subscription&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;Extension mechanism?&lt;/td&gt;&lt;td&gt;→ Add extensions module&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;Stateless?&lt;/td&gt;&lt;td&gt;→ Simplify connection/state mgmt&lt;/td&gt;&lt;/tr&gt;&lt;/table&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;align=left;verticalAlign=top;spacingLeft=8;spacingTop=4;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="600" y="460" width="280" height="210" as="geometry"/>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
