#lang ivy1.7

# =============================================================================
# Pattern:     export_weight_template
# Source:      QUIC quic_server_test_stream.ivy, quic_server_test_stop_sending_error.ivy
# Description: Export + weight attributes pattern for test files.
#              Exports make actions callable by the Ivy test harness.
#              Weight attributes bias the random test generator toward
#              specific actions, increasing coverage of interesting behaviors.
#
# Placeholders:
#   {prot}           - protocol name, lowercase (e.g., "quic", "bgp")
#   {PROT}           - protocol name, UPPERCASE
#   {base_test}      - base test file to include (e.g., "quic_server_test")
#   {frame_type}     - specific frame/message type being tested
#
# Cross-references:
#   - Extends:    finalize_template.ivy (often combined in same file)
#   - Depends on: base test file that defines the common test structure
#   - Related:    before_after_template.ivy (before monitors for constraints)
#
# Decision points:
#   1. Which actions to export (each export = one degree of freedom for generator)
#   2. Weight values: higher = more likely to be generated (default is "1")
#   3. Whether to include the base test or define everything inline
#
# Usage:
#   A typical test file includes a base test, then adds specific exports
#   and weights to focus the generator on the scenario under test.
# =============================================================================


# --- Include the base test file ---
# The base test defines common exports, before monitors, and initialization.
# This file adds scenario-specific exports and weights on top.
# include {base_test}


# --- Standard exports ---
# These are the common actions that most tests need to generate.
# TODO: uncomment and adjust for your protocol

# Core frame/message handlers
# export frame.ack.handle
# export frame.stream.handle
# export frame.crypto.handle
# export frame.path_response.handle

# Top-level events
# export packet_event
# export {prot}_send_event
# export tls_recv_event


# --- Scenario-specific exports ---
# Add exports for the specific frame/message type this test targets.
# Without an export, the action cannot be generated by the test harness.

# export frame.{frame_type}.handle


# --- Weight attributes ---
# Weights bias the random generator toward certain actions.
# Higher weight = more likely to be chosen when the generator picks
# the next action to execute. Default weight is "1".
#
# Use higher weights to:
#   - Focus testing on a specific message type
#   - Ensure rare-but-important actions occur more frequently
#   - Balance generation when some actions dominate naturally

# attribute frame.crypto.handle.weight = "5"
# attribute frame.path_response.handle.weight = "5"
# attribute frame.{frame_type}.handle.weight = "5"


# --- Finalize ---
# End-of-test assertions specific to this scenario.
# Can override or extend the base test's _finalize.

# export action _finalize = {
#     # TODO: scenario-specific assertions
#     # require is_protocol_violation;
# }
